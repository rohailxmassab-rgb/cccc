rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Catch-all (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() <= 150 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'preparing', 'out_for_delivery', 'delivered', 'cancelled'] &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 500 &&
             data.timestamp is timestamp;
    }

    // --- Collection Rules ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role &&
                      incoming().updatedAt is timestamp;
      allow delete: if false;
    }

    // MENU
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidMenuItem(incoming());
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      allow get: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isValidOrder(incoming()) && (
        (isSignedIn() && incoming().userId == request.auth.uid) ||
        (!isSignedIn() && incoming().userId == 'guest')
      );
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['confirmed', 'preparing', 'out_for_delivery', 'delivered', 'cancelled'];
    }

    // CARTS
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
